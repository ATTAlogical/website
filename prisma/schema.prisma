// Prisma schema for ATTA logical.
// Database: Neon Postgres. Edit + run `npx prisma migrate dev` after changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon: use direct (non-pooled) URL for migrations. If you only have one, set them both to the same.
  directUrl = env("DIRECT_URL")
}

// ─── Log entries ──────────────────────────────────────────────────────────────
// One row per moment in the ATTA logical universe. Branches: ATTA logical (atta),
// ATTA Laugical (laugical), ATTA CKORE (ckore). CKORE entries can optionally
// carry a Spotify URL — when present, oEmbed metadata is cached on the row.

model LogEntry {
  id           String   @id @default(cuid())
  /// Stable kebab-case slug — used for lineage (links).
  slug         String   @unique
  /// Date of the event (date only, no time).
  date         DateTime @db.Date
  /// One of: "atta" | "laugical" | "ckore"
  branch       String
  /// One of: "build" | "project" | "track" | "drop" | "note" | "milestone"
  type         String
  title        String
  body         String?
  /// Optional internal route or external URL.
  href         String?
  external     Boolean  @default(false)
  /// Slugs this entry grows out of. Directed edges; renders as connections in ATTLAS.
  links        String[]
  /// Slug of a parent entry — currently used for tracks that belong inside an
  /// album. Tracks with parentSlug are hidden in ATTLAS until the parent is
  /// hovered, then they "pop out" radially around the parent.
  parentSlug   String?

  /// CKORE-only. The raw Spotify track URL.
  spotifyUrl   String?
  /// Cached oEmbed title (e.g. "Untitled by CKORE").
  spotifyTitle String?
  /// Cached oEmbed album-art thumbnail URL.
  spotifyThumb String?
  /// Spotify Web API: track duration in milliseconds.
  spotifyDurationMs Int?
  /// Spotify Web API: release date string ("YYYY-MM-DD", "YYYY-MM", or "YYYY").
  spotifyReleaseDate String?
  /// Spotify Web API: primary artist name (comma-joined when multiple).
  spotifyArtist String?
  /// Spotify Web API: album name.
  spotifyAlbum String?
  /// Spotify Web API: 30s mp3 preview URL (may be null for some tracks).
  spotifyPreviewUrl String?
  /// Spotify Audio Features: tempo in BPM.
  spotifyTempo Float?
  /// Spotify Audio Features: 0..1, intensity.
  spotifyEnergy Float?
  /// Spotify Audio Features: 0..1, musical positiveness (sad → happy).
  spotifyValence Float?
  /// Spotify Audio Features: 0..1, danceability.
  spotifyDanceability Float?
  /// Spotify Web API: popularity 0..100 (only surfaced when admin toggle is on).
  spotifyPopularity Int?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([branch])
  @@index([date])
  @@index([parentSlug])
}

// ─── Site settings ────────────────────────────────────────────────────────────
// Single-row table for site-wide settings the admin can edit without touching
// code. Always upsert with id = 1 — there is only ever one row.

model SiteSettings {
  id              Int      @id @default(1)
  /// Spotify artist/user profile URL — surfaces in the ATTLAS music sidebar header.
  spotifyProfile  String?
  /// Spotify artist ID — drives auto-import of the whole discography.
  spotifyArtistId String?
  /// When true, surface follower count / popularity / monthly listeners on /temporal.
  /// Default false — vanity metrics off until Boelie wants them on.
  showSpotifyVanity Boolean @default(false)
  updatedAt       DateTime @updatedAt
}
